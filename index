      </div>
      <div class="calc-row">
        <label>Conserto Bateria Lítio <small>R$ 800 / unidade</small></label>
        <input type="number" min="0" value="0" data-price="800">
      </div>
      <div class="calc-row">
        <label>Reparo Carregador <small>R$ 320 / unidade</small></label>
        <input type="number" min="0" value="0" data-price="320">
      </div>
      <div class="calc-row">
        <label>Manutenção Preventiva <small>R$ 250 / visita</small></label>
        <input type="number" min="0" value="0" data-price="250">
      </div>
      <div class="calc-row">
        <label>Componentes Eletrônicos <small>R$ 80 / unidade</small></label>
        <input type="number" min="0" value="0" data-price="80">
      </div>
    </div>
    <div class="calc-total">
      <span>Total Estimado</span>
      <strong id="calcTotal">R$ 0,00</strong>
    </div>
    <div class="modal-actions">
      <button class="btn-primary" id="calcSend">Solicitar Orçamento Gratuito</button>
      <button class="btn-secondary" onclick="closeModal()">Fechar</button>
    </div>
  `);
  const inputs = modalContent.querySelectorAll('input[data-price]');
  const total = document.getElementById('calcTotal');
  function recalc() {
    let sum = 0;
    inputs.forEach(i => sum += (parseFloat(i.value) || 0) * parseFloat(i.dataset.price));
    total.textContent = 'R$ ' + sum.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
  inputs.forEach(i => i.addEventListener('input', recalc));
  document.getElementById('calcSend').addEventListener('click', () => {
    const items = [];
    inputs.forEach(i => {
      const q = parseInt(i.value) || 0;
      if (q > 0) items.push(`${q}x ${i.closest('.calc-row').querySelector('label').firstChild.textContent.trim()}`);
    });
    if (items.length === 0) { showToast('Adicione pelo menos um item', true); return; }
    openQuoteModal(items.join(', ') + ` — Total estimado: ${total.textContent}`);
  });
}

